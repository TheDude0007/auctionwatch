# ──────────────────────────────────────────────────
# AuctionWatch — Environment Configuration
# cp .env.example .env  then edit your values
# ──────────────────────────────────────────────────

# Server port
PORT=3010

# Daily scan cron (default: 8:00 AM every day)
# Format: minute hour day-of-month month weekday
SCAN_CRON=0 8 * * *

# Set to true to use simulated data instead of scraping Nellis
# Useful for UI development / testing without hitting the site
MOCK_MODE=false

# Set to false to watch the browser window during scans (debugging)
HEADLESS=true
